# Environment template. Copy to .env and fill real values:
#   cp .env.example .env
# .env is gitignored; this file (.env.example) is committed with placeholders.

# --- Model engine ---
# App settings are XLIT_-prefixed so no field collides with a system env var.
# In particular an unprefixed LANG would be shadowed by the POSIX locale var.
XLIT_ENGINE=ct2                                  # fairseq | ct2 | onnx
XLIT_DEVICE=cpu                                  # cpu | cuda (cuda only for benchmarking)
XLIT_LANG=hi                                     # default language code
XLIT_BEAM_WIDTH=5                                # beam width; MUST be >= XLIT_TOPK or you get fewer candidates
XLIT_TOPK=5                                      # number of candidates to return

# --- Paths ---
XLIT_DICT_PATH=server/data/dictionary_hi.json    # precomputed dictionary
XLIT_MODEL_DIR=models/indicxlit/ct2_int8         # model weights for the chosen engine

# --- Serving ---
XLIT_LRU_CACHE_SIZE=10000                        # max entries in the in-memory LRU cache
XLIT_LOG_LEVEL=info                              # logging level

# --- Operational (read by uvicorn CLI / docker, not the app config) ---
WORKERS=4                                         # uvicorn worker count
PORT=8000                                         # backend port

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000        # backend URL for the demo

# --- Optional: LLM-as-judge eval only ---
OPENAI_API_KEY=                                   # leave blank unless running LLM-judge eval
