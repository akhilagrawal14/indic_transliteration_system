# Environment template. Copy to .env and fill real values:
#   cp .env.example .env
# .env is gitignored; this file (.env.example) is committed with placeholders.

# --- Model engine ---
ENGINE=ct2                                      # fairseq | ct2 | onnx
DEVICE=cpu                                       # cpu | cuda (cuda only for benchmarking)
LANG=hi                                          # default language code
BEAM_WIDTH=5                                     # beam search width; MUST be >= TOPK or you get fewer candidates
TOPK=5                                           # number of candidates to return

# --- Paths ---
DICT_PATH=server/data/dictionary_hi.json         # precomputed dictionary
MODEL_DIR=models/indicxlit/ct2_int8              # model weights for the chosen engine

# --- Serving ---
LRU_CACHE_SIZE=10000                             # max entries in the in-memory LRU cache
WORKERS=4                                         # uvicorn worker count
PORT=8000                                         # backend port
LOG_LEVEL=info                                    # logging level

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000        # backend URL for the demo

# --- Optional: LLM-as-judge eval only ---
OPENAI_API_KEY=                                   # leave blank unless running LLM-judge eval
